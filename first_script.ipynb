    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "X = np.linspace(0, 2*np.pi, 100)\n",
    "Y=np.sin(X)\n",
    "plt.plot(X, Y)\n",
    "\n",
    "plt.title(\"ML adjacent plot.\")\n",
    "\n",
    "plt.savefig(\"day1.png\")"
   ]
  }
